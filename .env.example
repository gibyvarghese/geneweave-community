# geneWeave distribution configuration. Copy to `.env` and fill in.
# `node start.mjs` (or `npm start`) loads this file automatically.

# ── Server ──────────────────────────────────────────────
PORT=3500
HOST=127.0.0.1
# 'development' (default) or 'production'. Production enforces strong secrets + Redis.
NODE_ENV=development
# Sign-in tokens are signed with this. Use a long random string:  openssl rand -hex 32
JWT_SECRET=

# ── Model providers (set at least one) ──────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Which provider/model new chats use by default (overridable per-request + via admin routing).
GENEWEAVE_DEFAULT_PROVIDER=openai
GENEWEAVE_DEFAULT_MODEL=gpt-4o-mini

# ── Database ────────────────────────────────────────────
# SQLite file path. Postgres is supported via a custom adapter (see the README).
DB_PATH=./geneweave.db

# ── First-run admin bootstrap (optional) ────────────────
# On first boot, if this email is new, geneWeave creates a verified platform_admin
# so you have someone to sign in as. Never overwrites an existing user.
GENEWEAVE_ADMIN_EMAIL=
GENEWEAVE_ADMIN_PASSWORD=
GENEWEAVE_ADMIN_NAME=Administrator

# ── Optional integrations ───────────────────────────────
# CORS_ORIGIN=https://your-frontend.example.com
# REDIS_URL=redis://localhost:6379          # required in production for distributed rate limiting
# WEAVE_ENCRYPTION_MASTER_KEY=              # 32-byte hex/base64 to enable per-tenant encryption

# ── Guardrails ──────────────────────────────────────────
# Heavy LLM-judge guardrails (reasoning judges, hallucination/factuality, cognitive
# checks) are OPT-IN by default — they add latency + cost. Deterministic safety
# (PII redaction, prompt-injection, credential/SSRF filters, moderation) stays on.
# Set to 1 to seed the LLM judges enabled on a fresh database.
GENEWEAVE_ENABLE_LLM_JUDGES=0
# Model the LLM-judge guardrails use. Defaults to a capable model per provider —
# a weak judge (e.g. gpt-4o-mini) produces nonsense verdicts that block correct answers.
GUARDRAIL_JUDGE_PROVIDER=openai
GUARDRAIL_JUDGE_MODEL=gpt-4o
